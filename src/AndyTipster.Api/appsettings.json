{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Diagnostics.HealthChecks": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AndyTipster;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "AzureSql": {
    "GeoRedundantBackup": {
      "Enabled": true,
      "BackupStorageRedundancy": "Geo",
      "ShortTermRetentionDays": 7,
      "LongTermRetention": {
        "WeeklyRetention": "P4W",
        "MonthlyRetention": "P12M",
        "YearlyRetention": "P5Y",
        "WeekOfYear": 1
      },
      "Notes": "Azure SQL geo-redundant backup is configured at the Azure resource level. These settings document the intended backup policy for infrastructure provisioning (e.g., Bicep/ARM/Terraform). Short-term backups (PITR) allow point-in-time restore within 7 days. Long-term retention (LTR) stores weekly, monthly, and yearly backups in geo-redundant storage."
    }
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "AzureStorage": {
    "ConnectionString": "UseDevelopmentStorage=true"
  },
  "PayPal": {
    "BaseUrl": "https://api-m.sandbox.paypal.com/v1/",
    "ClientId": "",
    "ClientSecret": "",
    "WebhookId": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ],
    "ProductionOrigins": []
  },
  "AllowedHosts": "*"
}
